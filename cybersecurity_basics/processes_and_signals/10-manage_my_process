#!/usr/bin/env bash
# This script manages the manage_my_process daemon

PID_FILE="/tmp/my_process.pid"
PROCESS="./manage_my_process"

start_process() {
    "$PROCESS" &
    echo $! > "$PID_FILE"
    echo "manage_my_process started"
}

stop_process() {
    kill "$(cat "$PID_FILE")"
    rm -f "$PID_FILE"
    echo "manage_my_process stopped"
}

restart_process() {
    kill "$(cat "$PID_FILE")"
    rm -f "$PID_FILE"
    "$PROCESS" &
    echo $! > "$PID_FILE"
    echo "manage_my_process restarted"
}

case "$1" in
    start)
        start_process
        ;;
    stop)
        stop_process
        ;;
    restart)
        restart_process
        ;;
    *)
        echo "Usage: manage_my_process {start|stop|restart}"
        ;;
esac
